<UserControl
    x:Class="BookstoreManagement.SettingUI.SettingV"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dashboard="clr-namespace:BookstoreManagement.UI.DashboardUI"
    xmlns:local="clr-namespace:BookstoreManagement.SettingUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance local:SettingVM}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <DataTemplate DataType="{x:Type local:AVM}">
            <local:AV />
        </DataTemplate>
        <DataTemplate DataType="{x:Type local:BVM}">
            <local:BV />
        </DataTemplate>
        <DataTemplate DataType="{x:Type dashboard:DashBoardVM}">
            <dashboard:DashBoardV />
        </DataTemplate>
    </UserControl.Resources>
    <StackPanel>
        <TextBlock>SettingV works!</TextBlock>
        <Button Command="{Binding ACommand}">
            A
        </Button>
        <Button Command="{Binding BCommand}">
            B
        </Button>
        <Button Command="{Binding NavDashboardCommand}">
            Dashboard
        </Button>
        <ContentControl Content="{Binding NavigatorStore.CurrentViewModel}" />
    </StackPanel>
</UserControl>
